{
	"name": "@use-pico/cls",
	"description": "Type-safe, composable styling system for React, Vue, Svelte, and vanilla JS",
	"version": "workspace:*",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"build:bundle": "bun x rollup -c",
		"no:build": "run-p build:*",
		"no:test": "run-s test:*",
		"test:code": "vitest --run",
		"knip": "knip --include dependencies --no-config-hints"
	},
	"dependencies": {
		"react": "19.2.4",
		"tailwind-merge": "3.5.0"
	},
	"devDependencies": {
		"@aminnairi/rollup-plugin-external": "0.1.3",
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@testing-library/jest-dom": "6.9.1",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260320.1",
		"@use-pico/tsconfig": "5.0.0",
		"@vitejs/plugin-react": "6.0.1",
		"jsdom": "29.0.1",
		"knip": "6.0.1",
		"npm-run-all2": "8.0.4",
		"rollup": "4.59.0",
		"rollup-plugin-dts": "6.4.0",
		"typescript": "beta",
		"vitest": "4.1.0"
	},
	"main": "src/index.ts",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"files": [
		"src",
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"license": "MIT",
	"repository": "use-pico/pico",
	"homepage": "https://github.com/use-pico/pico#readme",
	"bugs": "https://github.com/use-pico/pico/issues",
	"keywords": [
		"component-variants",
		"css",
		"design-system",
		"design-tokens",
		"styling",
		"type-safe",
		"typescript"
	],
	"readme": "README.md"
}
