{
	"name": "@use-pico/client",
	"description": "Client-side stuff",
	"version": "workspace:*",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build:bundle": "bun x rollup -c",
		"no:build": "bun run build:bundle",
		"knip": "knip --include dependencies --no-config-hints"
	},
	"dependencies": {
		"@tanstack/react-query": "5.91.2",
		"@tanstack/react-router": "1.168.1",
		"@types/luxon": "3.7.1",
		"@use-pico/cls": "workspace:*",
		"@use-pico/common": "workspace:*",
		"luxon": "3.7.2",
		"motion": "12.38.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "10.1.0",
		"react-modal-sheet": "5.5.0",
		"remark-gfm": "4.0.1",
		"use-debounce": "10.1.0",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@aminnairi/rollup-plugin-external": "0.1.3",
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@typescript/native-preview": "7.0.0-dev.20260320.1",
		"@use-pico/tsconfig": "5.0.0",
		"knip": "6.0.0",
		"rollup": "4.59.0",
		"rollup-plugin-dts": "6.4.0",
		"typescript": "beta"
	},
	"files": [
		"src"
	],
	"exports": {
		"./ui/*": {
			"import": "./src/ui/*/index.ts"
		},
		"./ui.css": "./src/ui.css",
		"./*": {
			"import": "./src/*/index.ts"
		}
	},
	"license": "MIT",
	"repository": "use-pico/pico",
	"homepage": "https://github.com/use-pico/pico#readme",
	"bugs": "https://github.com/use-pico/pico/issues"
}
