{
	"name": "@use-pico/server",
	"description": "Node/bun/whatever/server-side stuff.",
	"version": "workspace:*",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"no:build": "bun x rollup -c",
		"no:test": "run-s test:*",
		"test:code": "vitest --run",
		"knip": "knip --include dependencies --no-config-hints"
	},
	"dependencies": {
		"@phenomnomnominal/tsquery": "6.1.4",
		"@types/cli-progress": "3.11.6",
		"@use-pico/common": "workspace:*",
		"cli-progress": "3.12.0",
		"timer-node": "5.0.9",
		"yaml": "2.8.2"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@typescript/native-preview": "7.0.0-dev.20260320.1",
		"@use-pico/tsconfig": "5.0.0",
		"knip": "6.0.0",
		"npm-run-all2": "8.0.4",
		"react": "19.2.4",
		"rollup": "4.59.0",
		"rollup-plugin-dts": "6.4.0",
		"typescript": "beta",
		"vitest": "4.1.0"
	},
	"files": [
		"src"
	],
	"exports": {
		"./*": {
			"types": "./src/*/index.ts",
			"import": "./src/*/index.ts"
		}
	},
	"license": "MIT",
	"repository": "use-pico/pico",
	"homepage": "https://github.com/use-pico/pico#readme",
	"bugs": "https://github.com/use-pico/pico/issues"
}
