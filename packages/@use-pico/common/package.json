{
	"name": "@use-pico/common",
	"description": "Shared stuff between client/server.",
	"version": "workspace:*",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"no:build": "bun x rollup -c",
		"no:test": "vitest --run",
		"knip": "knip --include dependencies --no-config-hints"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "3.3.0",
		"@types/luxon": "3.7.1",
		"@types/qs": "6.15.0",
		"fast-clean": "1.5.3",
		"is-string": "1.1.1",
		"js-sha256": "0.11.1",
		"kysely": "0.28.14",
		"luxon": "3.7.2",
		"preferred-locale": "2.0.2",
		"qs": "6.15.0",
		"ts-pattern": "5.9.0",
		"xxhash-wasm": "1.1.0",
		"zod": "4.3.6"
	},
	"peerDependencies": {
		"effect": "3.21.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@types/node": "25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260320.1",
		"@use-pico/tsconfig": "5.0.0",
		"effect": "3.21.0",
		"knip": "6.0.1",
		"rollup": "4.59.0",
		"rollup-plugin-dts": "6.4.0",
		"typescript": "beta",
		"vitest": "4.1.0"
	},
	"files": [
		"src"
	],
	"exports": {
		"./*": {
			"types": "./src/*/index.ts",
			"import": "./src/*/index.ts"
		}
	},
	"license": "MIT",
	"repository": "use-pico/pico",
	"homepage": "https://github.com/use-pico/pico#readme",
	"bugs": "https://github.com/use-pico/pico/issues"
}
