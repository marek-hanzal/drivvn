{
	"name": "@drivvn/sdk",
	"description": "SDK layer (queries/mutations) for frontend to keep the stuff clear and shiny",
	"version": "workspace:*",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"sdk": "openapi-ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"axios": "1.13.6",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@hey-api/openapi-ts": "0.94.4",
		"@types/node": "25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260320.1",
		"@use-pico/tsconfig": "5.0.0",
		"knip": "6.0.0",
		"typescript": "beta",
		"vite": "8.0.0-beta.18"
	},
	"exports": {
		"./api/*": {
			"import": "./src/api/*/index.ts",
			"require": "./src/api/*/index.ts"
		},
		"./mutation/*": {
			"import": "./src/mutation/*/index.ts",
			"require": "./src/mutation/*/index.ts"
		},
		"./query/*": {
			"import": "./src/query/*/index.ts",
			"require": "./src/query/*/index.ts"
		}
	}
}
