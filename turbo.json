{
	"$schema": "https://turborepo.org/schema.json",
	"envMode": "loose",
	"globalDependencies": [
		"tsconfig.json",
		"bun.lock",
		"package.json"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"preview": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"inputs": [
				"src/**",
				"tsconfig.json"
			],
			"outputs": [],
			"outputLogs": "new-only",
			"cache": false
		},
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"src/**",
				"vite.config.ts",
				"tsconfig.json",
				"tailwind.config.ts",
				"nitro.config.ts"
			],
			"outputs": [
				".vercel/output/**",
				"dist/**"
			],
			"outputLogs": "new-only",
			"cache": false
		},
		"sdk": {
			"cache": false
		},
		"test": {
			"outputs": [],
			"outputLogs": "new-only",
			"cache": false
		}
	}
}
